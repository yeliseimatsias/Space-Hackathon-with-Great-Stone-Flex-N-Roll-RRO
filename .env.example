TELEGRAM_BOT_TOKEN=123456:ABCDEF-example-token
BASE_URL=https://your-subdomain.ngrok-free.app
BITRIX_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/1/your-webhook-token/
# Имя БД совпадает с docker/docker-compose.yml (POSTGRES_DB=flexnroll)
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/flexnroll
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
KNOWLEDGE_THRESHOLD=0.75
LLM_API_KEY=your-google-ai-studio-key
# См. https://ai.google.dev/gemini-api/docs/models — не используйте gemini-1.5 (сняты с API).
LLM_MODEL=gemini-2.5-flash
LOG_LEVEL=INFO
# PRIMARY_BITRIX_USER_ID=1
# По умолчанию true: PRIMARY только для sales; false = все задачи на PRIMARY
# BITRIX_PRIMARY_USER_ID_SALES_ONLY=true
# Один диспетчер на все im-уведомления; не задано = уведомление ответственному эксперту
# BITRIX_IM_OPERATOR_USER_ID=1
# BITRIX_SEND_CLIENT_MESSAGES_TO_IM=true
# BITRIX_CREATE_TASK_ON_ROUTING=true
# Секрет для POST /webhook/bitrix/reply и GET /operator/reply
# BITRIX_REPLY_WEBHOOK_SECRET=your-long-random-secret
